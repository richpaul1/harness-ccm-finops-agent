# Auth — set at least one of:
# - HARNESS_API_KEY (PAT / service account) for all APIs
#HARNESS_API_KEY=pat.xxxxx.xxxxx.xxxxx
# - HARNESS_BEARER_TOKEN (browser session JWT) for CCM `/ccm/*` only; non-CCM tools still need HARNESS_API_KEY
HARNESS_BEARER_TOKEN=eyJ...
HARNESS_ACCOUNT_ID=your-account-id

# Optional — defaults shown
HARNESS_BASE_URL=https://app.harness.io
PORT=3000
HARNESS_DEFAULT_ORG_ID=default
HARNESS_API_TIMEOUT_MS=30000
HARNESS_MAX_RETRIES=3

LOG_LEVEL=debug
HARNESS_LOG_REQUEST_FILE=request.log

# ─── Voice / narrated-video feature flag ────────────────────────────────────
# Master switch for the narrated-video pipeline. When false (default) the
# `harness_ccm_finops_video_render` MCP tool is NOT registered, the bundled
# Acme report template ships without a `<!-- voice: ... -->` tag, and the
# agent has no surface telling it to author voice narration.
#
# Set to `true` ONLY when you have at least one TTS provider configured
# below. Otherwise the agent will offer a tool that immediately fails on use.
#HARNESS_VOICE_ENABLED=false

# Optional — narrated video render (harness_ccm_finops_video_render).
# Requires HARNESS_VOICE_ENABLED=true above.
# Set ONE provider's env vars; the renderer auto-discovers in this order
# (local → openai → elevenlabs → azure → google). When none are set, voice
# comments are detected and recorded in the slide manifest but the MP4 is
# silent.

# Local OpenAI-compatible TTS server (Orpheus-FastAPI, Kokoro-FastAPI,
# LMStudio, vLLM with audio model, etc.). Only LOCAL_TTS_BASE_URL is
# required; model/voice/key are optional. Server must speak the OpenAI
# `POST /v1/audio/speech` protocol and return audio/mpeg.
#LOCAL_TTS_BASE_URL=http://localhost:5005
#LOCAL_TTS_MODEL=orpheus
#LOCAL_TTS_VOICE=tara
#LOCAL_TTS_API_KEY=anything

#OPENAI_API_KEY=sk-...
#ELEVENLABS_API_KEY=...
#AZURE_SPEECH_KEY=...
#AZURE_SPEECH_REGION=eastus
#GOOGLE_TTS_API_KEY=...

# Optional — caption burn-in appearance (harness_ccm_finops_video_render with captions=true)
# CAPTION_BAR_HEIGHT  — dedicated dark bar at the bottom of every frame in actual output
#                       pixels. Slide content is captured at (videoHeight - barHeight) so
#                       nothing bleeds into the bar. Default 120px (≈11% of 1080p).
#                       ⚠ Make sure: lines × fontsize × 1.2 ≤ barHeight × (288/videoHeight)
#                         e.g. defaults: 2 × 11 × 1.2 = 26.4 ≤ 120×288/1080 = 32 ✓
# CAPTION_BAR_COLOR   — hex RGB of the bar fill, no leading #. Default near-black 0d0d0d.
# CAPTION_FONTSIZE    — libass virtual px at PlayRes 288; actual ≈ fontsize × (videoH/288)
#                       Default 11 → ~41px actual at 1080p (Netflix-standard ~36-40px).
# CAPTION_MAX_LINES   — pages of text shown before scrolling forward (default 2)
# CAPTION_LINE_WIDTH  — characters per wrapped line. MUST be narrow enough that
#                       libass does NOT re-wrap further; the formula is:
#                         max = floor((384 - MarginL - MarginR) / (fontsize × 0.55))
#                         at fontsize=11: max ≈ floor(304/6.05) = 50 chars
#                       Default 55 gives ~6 chars safety margin. ⚠ 100 chars is
#                       too wide — libass will auto-wrap each line into ~3 visual
#                       lines, causing text to overflow the bar into the slide.
# CAPTION_FONT        — font name available to FFmpeg/libass (default Arial)
#CAPTION_BAR_HEIGHT=120
#CAPTION_BAR_COLOR=0d0d0d
#CAPTION_FONTSIZE=11
#CAPTION_MAX_LINES=2
#CAPTION_LINE_WIDTH=55
#CAPTION_FONT=Arial
