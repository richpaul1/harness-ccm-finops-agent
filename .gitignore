# Generated by `pnpm build:codemirror` (esbuild bundles CodeMirror 6 into a
# single served-from-disk module so the live edit panel never depends on
# a public CDN). Re-built every pnpm build; safe to ignore.
src/report-renderer/static/public/codemirror.bundle.js

# This project uses pnpm as the package manager (see `packageManager` field
# in package.json). Only `pnpm-lock.yaml` is the authoritative lockfile —
# ignore npm/yarn lockfiles so a stray `npm install` / `yarn install` never
# re-introduces them and causes dependency drift.
package-lock.json
yarn.lock
.env copy

